# RB-Rules v2 op de Server-setup VM. Genereer sterke waarden: openssl rand -base64 32

# Extern Caddy-netwerk (docker inspect caddy -f '{{json .NetworkSettings.Networks}}')
CADDY_NETWORK=

POSTGRES_PASSWORD=
NEO4J_PASSWORD=rbrules-neo4j
NEO4J_HEAP_MAX=512m
NEO4J_PAGECACHE=384m

# AI-sidecar: Claude-abonnement (OAuth via `claude setup-token`) of API-key.
# Laat de ander leeg — ANTHROPIC_API_KEY wint stilletjes als beide gezet zijn.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=
