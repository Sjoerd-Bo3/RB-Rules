# RB-Rules v2 op de Server-setup VM. Genereer sterke waarden: openssl rand -base64 32

# Extern Caddy-netwerk (docker inspect caddy -f '{{json .NetworkSettings.Networks}}')
CADDY_NETWORK=

# Image-tag voor de rb-*-images. Normaal LEEG laten: handmatig `up -d` draait
# dan op :latest, en de deploy-workflow pint per run de commit-SHA via een
# export op het SSH-commando (staat dus bewust niet in deze file).
#IMAGE_TAG=latest

POSTGRES_PASSWORD=
# Kies een eigen waarde (zoals alle velden hier) — een ingevulde default blijft staan.
NEO4J_PASSWORD=
NEO4J_HEAP_MAX=512m
NEO4J_PAGECACHE=384m

# AI-sidecar: één account via de ongenummerde fallback, OF twee geïsoleerde
# slots. Zodra een genummerde variabele niet-leeg is worden de ongenummerde waarden
# voor die provider genegeerd. Per Claude-slot exact één authmethode invullen.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN_1=
ANTHROPIC_API_KEY_1=
CLAUDE_CODE_OAUTH_TOKEN_2=
ANTHROPIC_API_KEY_2=

# Codex: trusted access token en/of een eigen reeds aangemelde CODEX_HOME.
# De twee paden hieronder corresponderen met de schrijfbare datadisk-mounts in
# docker-compose.yml. Gebruik /var/lib/rb-ai/codex-1 ook voor een ongenummerde
# single-accountfallback; laat leeg wanneer dat slot niet gebruikt wordt.
CODEX_ACCESS_TOKEN=
CODEX_HOME=
CODEX_ACCESS_TOKEN_1=
CODEX_HOME_1=
CODEX_ACCESS_TOKEN_2=
CODEX_HOME_2=

# Beheer (/admin — rb-web login + rb-api X-Admin-Key)
ADMIN_PASSWORD=

# Web-push (#28) — genereer één keer: npx web-push generate-vapid-keys
# Leeg laten = push uitgeschakeld (subscribe-knop verschijnt dan niet).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:beheer@bo3.dev
