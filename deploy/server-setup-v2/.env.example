# RB-Rules v2 op de Server-setup VM. Genereer sterke waarden: openssl rand -base64 32

# Extern Caddy-netwerk (docker inspect caddy -f '{{json .NetworkSettings.Networks}}')
CADDY_NETWORK=

# Image-tag voor de rb-*-images. Normaal LEEG laten: handmatig `up -d` draait
# dan op :latest, en de deploy-workflow pint per run de commit-SHA via een
# export op het SSH-commando (staat dus bewust niet in deze file).
#IMAGE_TAG=latest

POSTGRES_PASSWORD=
NEO4J_PASSWORD=rbrules-neo4j
NEO4J_HEAP_MAX=512m
NEO4J_PAGECACHE=384m

# AI-sidecar: Claude-abonnement (OAuth via `claude setup-token`) of API-key.
# Laat de ander leeg — ANTHROPIC_API_KEY wint stilletjes als beide gezet zijn.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

# Beheer (/admin — rb-web login + rb-api X-Admin-Key)
ADMIN_PASSWORD=

# Web-push (#28) — genereer één keer: npx web-push generate-vapid-keys
# Leeg laten = push uitgeschakeld (subscribe-knop verschijnt dan niet).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:beheer@bo3.dev
