# RB-Rules op de Server-setup VM. Genereer sterke waarden: openssl rand -base64 32

# Naam van het bestaande externe Docker-netwerk waar je Caddy op zit.
# Vind het met:  docker inspect caddy -f '{{json .NetworkSettings.Networks}}'
CADDY_NETWORK=

# Databases
POSTGRES_PASSWORD=
NEO4J_PASSWORD=rbrules-neo4j

# Beheer (/admin)
ADMIN_PASSWORD=

# AI / Q&A — Claude-abonnement (OAuth) of API-key; laat de ander leeg.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

# Embeddings — lokaal (gratis, default) of Voyage.
#   ollama = lokaal via de rb-rules-ollama container (geen key)
#   voyage = Voyage AI (vereist VOYAGE_API_KEY)
EMBEDDINGS_PROVIDER=ollama
OLLAMA_EMBED_MODEL=nomic-embed-text
VOYAGE_API_KEY=
