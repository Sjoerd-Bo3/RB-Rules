# RB-Rules op de Server-setup VM. Genereer sterke waarden: openssl rand -base64 32

# Naam van het bestaande externe Docker-netwerk waar je Caddy op zit.
# Vind het met:  docker inspect caddy -f '{{json .NetworkSettings.Networks}}'
CADDY_NETWORK=

# Databases
POSTGRES_PASSWORD=
NEO4J_PASSWORD=rbrules-neo4j

# Beheer (/admin)
ADMIN_PASSWORD=

# AI / Q&A — Claude-abonnement (OAuth) of API-key; laat de ander leeg.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=
# Embeddings voor Q&A (gratis tier dekt de ingest)
VOYAGE_API_KEY=
