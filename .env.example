# ─── Databases ────────────────────────────────────────────────
# In Docker (compose) praat de app via servicenamen; deze waarden zijn voor
# het draaien van scripts/dev OP de host. In de compose-stack worden ze
# overschreven naar postgres:5432 / neo4j:7687.
DATABASE_URL=postgres://rbrules:rbrules@localhost:5432/rbrules
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=rbrules-neo4j

# Neo4j-geheugen (defaults afgestemd op ~8 GB VM, bv. Azure B2ms).
# Kleinere host (bv. 4 GB)? Zet heap/max op 512m en pagecache op 512m.
NEO4J_HEAP_INIT=1g
NEO4J_HEAP_MAX=2g
NEO4J_PAGECACHE=1g

# ─── Publiek (Azure) HTTPS via Caddy ─────────────────────────
# Vul je domein in en draai met: docker compose --profile public up -d
DOMAIN=rules.voorbeeld.nl

# ─── AI (Fase 2) ─────────────────────────────────────────────
# Voorkeur: Claude-abonnement via OAuth-token (geen per-token API-kosten).
# Genereer met de Claude CLI: `claude setup-token`. Zie docs/AI_AUTH.md.
CLAUDE_CODE_OAUTH_TOKEN=
# Alternatief: pay-per-token API-key (laat leeg als je het abonnement gebruikt).
ANTHROPIC_API_KEY=
# Embeddings (los van het abonnement; gratis tier dekt de ingest).
VOYAGE_API_KEY=
